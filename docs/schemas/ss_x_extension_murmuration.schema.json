{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ss_x_extension_murmuration/1",
  "title": "ss_x_extension_murmuration",
  "description": "Stage M5 / PR-1: the X-extension of the Sawin–Sutherland height murmuration (arXiv:2504.12295, Conjecture 1) to the 2^16 rung. Same statistic (1), extractor, τ and Δu as M4 — only X changes (docs/preregistered/PR-1.md). claim_class carries the committed single-rung verdict IN WORDS: partial agreement — the trough is PERSISTENT at 2^16 (dev identical to the 10^4 anchor, flat over 6.5x X) → Reading B 'consistent with persistent, proceed to PR-2' (EVIDENCE-GRADE, not the finite-X verdict, which requires the full ladder); the interpolated zero-crossing retreated (sub-bin, reported, not the gate). The <=10^4 ladder rows reproduce the frozen M4 run (consistency twin). No proof is claimed (rule 7).",
  "type": "object",
  "required": ["schema", "generated_by", "params", "empirical", "density", "shape", "convergence"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "ss_x_extension_murmuration/1"},
    "generated_by": {"type": "string"},
    "params": {
      "type": "object",
      "required": ["family", "statistic", "source", "external_data", "provenance",
                   "claim_class", "single_rung_reading", "consistency_twin",
                   "run_provenance", "X_confirm", "n_curves", "du", "tol",
                   "reading_A_fired", "density_trunc_B", "u_axis"],
      "additionalProperties": false,
      "properties": {
        "family": {"type": "string"},
        "statistic": {"type": "string"},
        "source": {"type": "string"},
        "external_data": {"type": "string"},
        "provenance": {"type": "string"},
        "claim_class": {"type": "string"},
        "single_rung_reading": {"type": "string"},
        "consistency_twin": {"type": "string"},
        "run_provenance": {"type": "string"},
        "X_confirm": {"type": "number"},
        "n_curves": {"type": "integer", "minimum": 1},
        "du": {"type": "number"},
        "tol": {"type": "number"},
        "reading_A_fired": {"type": "boolean"},
        "density_trunc_B": {"type": "integer", "minimum": 1},
        "u_axis": {"type": "string"}
      }
    },
    "empirical": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "emp", "count"],
        "additionalProperties": false,
        "properties": {
          "u": {"type": "number"}, "emp": {"type": "number"},
          "count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "density": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "d"],
        "additionalProperties": false,
        "properties": {"u": {"type": "number"}, "d": {"type": "number"}}
      }
    },
    "shape": {
      "type": "object",
      "required": ["targets", "empirical", "dev", "within_tol", "windowed_trough_u", "windowed_note", "refuted_hypothesis"],
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "empirical": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "dev": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "within_tol": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "boolean"}, "zero": {"type": "boolean"}, "trough": {"type": "boolean"}}
        },
        "windowed_trough_u": {"type": "number"},
        "windowed_note": {"type": "string"},
        "refuted_hypothesis": {"type": "string"}
      }
    },
    "convergence": {
      "type": "object",
      "required": ["note", "points"],
      "additionalProperties": false,
      "properties": {
        "note": {"type": "string"},
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["X", "n_curves", "hump", "zero", "trough", "dev_zero", "dev_trough"],
            "additionalProperties": false,
            "properties": {
              "X": {"type": "number"}, "n_curves": {"type": "integer"},
              "hump": {"type": "number"}, "zero": {"type": "number"},
              "trough": {"type": "number"}, "dev_zero": {"type": "number"},
              "dev_trough": {"type": "number"}
            }
          }
        }
      }
    }
  }
}
