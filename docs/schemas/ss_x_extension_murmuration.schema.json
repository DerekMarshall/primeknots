{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ss_x_extension_murmuration/1",
  "title": "ss_x_extension_murmuration",
  "description": "Stage M5 / PR-1: the X-extension of the Sawin–Sutherland height murmuration (arXiv:2504.12295, Conjecture 1) over the four-rung ladder X in {10^4, 2^16, 2^17, 2^18}. Same statistic (1), extractor, τ and Δu as M4 — only X changes (docs/preregistered/PR-1.md). claim_class + ladder_verdict carry the committed Rung-3 finite-range verdict IN WORDS: partial agreement — hump + first zero-crossing within the a-priori τ=0.06 at every rung, while the trough is a PERSISTENT open deviation (u=0.8875, dev 0.0825 flat across all four rungs, no ≥Δu recovery at either extension step) → VERDICT H0 (persistent, ≤2^18), a finite-range statement, explicitly NOT the X→∞ verdict [SS25] describe (2^18 is the bottom of their 2^16–2^28 window). Supporting empirics (not the gate): the sub-bin zero-crossing is flat/non-monotone; the trough depth eases while its position holds. The 2^18 rung is M0b-produced, validated by full-precision twins before the verdict is read. No proof is claimed (rule 7).",
  "type": "object",
  "required": ["schema", "generated_by", "params", "empirical", "density", "shape", "convergence"],
  "additionalProperties": false,
  "properties": {
    "schema": {"const": "ss_x_extension_murmuration/1"},
    "generated_by": {"type": "string"},
    "params": {
      "type": "object",
      "required": ["family", "statistic", "source", "external_data", "provenance",
                   "claim_class", "ladder_verdict", "consistency_twin",
                   "run_provenance", "X_confirm", "n_curves", "du", "tol",
                   "verdict", "density_trunc_B", "u_axis"],
      "additionalProperties": false,
      "properties": {
        "family": {"type": "string"},
        "statistic": {"type": "string"},
        "source": {"type": "string"},
        "external_data": {"type": "string"},
        "provenance": {"type": "string"},
        "claim_class": {"type": "string"},
        "ladder_verdict": {"type": "string"},
        "consistency_twin": {"type": "string"},
        "run_provenance": {"type": "string"},
        "X_confirm": {"type": "number"},
        "n_curves": {"type": "integer", "minimum": 1},
        "du": {"type": "number"},
        "tol": {"type": "number"},
        "verdict": {"type": "string", "enum": ["H0", "H1", "ambiguous"]},
        "density_trunc_B": {"type": "integer", "minimum": 1},
        "u_axis": {"type": "string"}
      }
    },
    "empirical": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "emp", "count"],
        "additionalProperties": false,
        "properties": {
          "u": {"type": "number"}, "emp": {"type": "number"},
          "count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "density": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["u", "d"],
        "additionalProperties": false,
        "properties": {"u": {"type": "number"}, "d": {"type": "number"}}
      }
    },
    "shape": {
      "type": "object",
      "required": ["targets", "empirical", "dev", "within_tol", "windowed_trough_u", "windowed_note", "refuted_hypothesis"],
      "additionalProperties": false,
      "properties": {
        "targets": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "empirical": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "dev": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "number"}, "zero": {"type": "number"}, "trough": {"type": "number"}}
        },
        "within_tol": {
          "type": "object",
          "required": ["hump", "zero", "trough"],
          "additionalProperties": false,
          "properties": {"hump": {"type": "boolean"}, "zero": {"type": "boolean"}, "trough": {"type": "boolean"}}
        },
        "windowed_trough_u": {"type": "number"},
        "windowed_note": {"type": "string"},
        "refuted_hypothesis": {"type": "string"}
      }
    },
    "convergence": {
      "type": "object",
      "required": ["note", "points"],
      "additionalProperties": false,
      "properties": {
        "note": {"type": "string"},
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["X", "n_curves", "hump", "zero", "trough", "dev_zero", "dev_trough"],
            "additionalProperties": false,
            "properties": {
              "X": {"type": "number"}, "n_curves": {"type": "integer"},
              "hump": {"type": "number"}, "zero": {"type": "number"},
              "trough": {"type": "number"}, "dev_zero": {"type": "number"},
              "dev_trough": {"type": "number"}
            }
          }
        }
      }
    }
  }
}
