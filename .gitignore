# Build output
/build/
/build-*/

# Emitted visualization data: a deliberate committed snapshot (regenerable by
# `at emit`) so the explainer deck's live-viewer iframes render on GitHub Pages.
# Small text JSON, none > 1 MB; re-emit to refresh.

# Odlyzko zero table (~1.8 MB): regenerated by oracle/fetch_odlyzko.py,
# verified against the committed data/odlyzko/MANIFEST.json checksum.
/data/odlyzko/zeros1

# Local editor / tool state
/.claude/settings.local.json
/.spyc-context-*.json
.DS_Store

# Python venv for the JSON-schema validator (verify/validate_json.py)
/.venv/

# Common C/C++ artifacts (out-of-tree builds should keep these empty, but just in case)
*.o
*.obj
*.a
*.so
*.dylib
*.exe

# PDF gitignore is scoped to docs/papers/ ONLY — the third-party copyrighted PDFs (see
# docs/papers/README.md). This is the copyright firewall (ERRATA #13): keep it the SOLE
# *.pdf ignore so no paper is committed by accident. Our OWN PDF build products — the
# data-note render (docs/notes/data-note/data-note.pdf), its figures, and docs/deck/deck.pdf —
# are committed as a reviewer convenience.
/docs/papers/*.pdf

# Cremona ecdata (M0): fetched by oracle/fetch_ecdata.py at a pinned commit,
# verified against data/cremona/MANIFEST.json. Data files not committed; the
# manifest + README are. (Mirrors the Odlyzko precedent above.)
/data/cremona/allcurves.*
/data/cremona/aplist.*
/data/cremona/curvedata.*

# a_p cache (M0, ARCHITECTURE-M §4): a derived artifact with provenance, never
# committed — regenerated by script, invalidated by generator-hash mismatch.
/data/apcache/

# ss-run crash-safety checkpoints (M5/PR-1): transient, complete=0, removed on
# completion. Never committed (the FINAL complete=1 partials file is). tmp+rename.
*.ckpt
*.ckpt.tmp

# Exception (data-note §5 item-4 libm diff): this ONE abandoned laptop 2^17 ckpt is
# force-committed — it is the diff's quantity-2 input and the only diff input not
# reproducible from source. See docs/notes/libm-partial-diff-spec.md. The 771 MB a_p
# cache (ap_cache_*.bin) stays ignored (hash-only in the spec).
!data/m5/ss_partials_x131072.txt.ckpt

# M0b reference a_p caches (Phase 2b): local, gitignored — large (~GB), generator-hash-
# verified, regenerated by `at ap-cache`; consumers refuse a stale OR partial cache (R1).
# Never committed (the ERRATA #18 "checksummed-not-committed" distinction).
data/m5/ap_cache_*.bin

# libm-diff quantity-1 sample outputs (data-note §5): reboot-proof local copies of the
# cross-platform a_p sample; regenerable via `at ap-sample`, sha-pinned in the spec.
data/m5/ap_sample_*.txt

# Python bytecode cache (from oracle/*.py runs)
__pycache__/
*.pyc

# Claude Code local settings (machine-local hooks: absolute paths, spyc integration)
.claude/settings.json
.claude/settings.local.json
