# Build output
/build/
/build-*/

# Emitted visualization data: a deliberate committed snapshot (regenerable by
# `at emit`) so the explainer deck's live-viewer iframes render on GitHub Pages.
# Small text JSON, none > 1 MB; re-emit to refresh.

# Odlyzko zero table (~1.8 MB): regenerated by oracle/fetch_odlyzko.py,
# verified against the committed data/odlyzko/MANIFEST.json checksum.
/data/odlyzko/zeros1

# Local editor / tool state
/.claude/settings.local.json
/.spyc-context-*.json
.DS_Store

# Python venv for the JSON-schema validator (verify/validate_json.py)
/.venv/

# Common C/C++ artifacts (out-of-tree builds should keep these empty, but just in case)
*.o
*.obj
*.a
*.so
*.dylib
*.exe

# Third-party paper PDFs (copyright): kept local, see docs/papers/README.md
/docs/papers/*.pdf

# Cremona ecdata (M0): fetched by oracle/fetch_ecdata.py at a pinned commit,
# verified against data/cremona/MANIFEST.json. Data files not committed; the
# manifest + README are. (Mirrors the Odlyzko precedent above.)
/data/cremona/allcurves.*
/data/cremona/aplist.*
/data/cremona/curvedata.*

# a_p cache (M0, ARCHITECTURE-M §4): a derived artifact with provenance, never
# committed — regenerated by script, invalidated by generator-hash mismatch.
/data/apcache/

# Python bytecode cache (from oracle/*.py runs)
__pycache__/
*.pyc

# Claude Code local settings (machine-local hooks: absolute paths, spyc integration)
.claude/settings.json
.claude/settings.local.json
