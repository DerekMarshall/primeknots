{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "'/opt/homebrew/bin/spyc' --report-status blocked",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "'/opt/homebrew/bin/spyc' --report-status blocked",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "'/opt/homebrew/bin/spyc' --report-status blocked",
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion|ExitPlanMode"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "'/opt/homebrew/bin/spyc' --report-status done",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "'/opt/homebrew/bin/spyc' --report-status working",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
